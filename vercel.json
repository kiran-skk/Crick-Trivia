{
  "version": 2,
  "rewrites": [
    { "source": "/play",    "destination": "/Cricket%20Trivia%20A.dc.html" },
    { "source": "/trivia",  "destination": "/Cricket%20Trivia%20A.dc.html" },
    { "source": "/guess",   "destination": "/CrickGuess.dc.html" },
    { "source": "/options", "destination": "/Cricket%20Trivia%20Options.dc.html" }
  ],
  "headers": [
    {
      "source": "/(.*)\\.js",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600, stale-while-revalidate=86400" }
      ]
    },
    {
      "source": "/(.*)\\.html",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    }
  ]
}
